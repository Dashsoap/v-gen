generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Authentication (NextAuth) ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  accounts   Account[]
  sessions   Session[]
  preference UserPreference?
  projects   Project[]
  tasks      Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User Preferences ──────────────────────────────────────────────────────

model UserPreference {
  id     String @id @default(cuid())
  userId String @unique

  customProviders String? @db.Text
  customModels    String? @db.Text

  defaultLlmModel   String?
  defaultImageModel  String?
  defaultVideoModel  String?
  defaultAudioModel  String?

  ttsVoice String @default("alloy")

  defaultAspectRatio String @default("16:9")
  defaultStyle       String @default("realistic")
  locale             String @default("zh")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id     String @id @default(cuid())
  userId String

  title       String
  description String? @db.Text

  // Source video
  sourceVideoUrl String? @db.Text
  analyzedText   String? @db.LongText
  rewrittenText  String? @db.LongText

  // Configuration
  style       String @default("realistic")
  aspectRatio String @default("16:9")
  status      String @default("draft") // draft | analyzing | analyzed | rewriting | rewritten | storyboarding | generating | completed

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodes Episode[]
  tasks    Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("projects")
}

// ─── Episodes ───────────────────────────────────────────────────────────────

model Episode {
  id        String @id @default(cuid())
  projectId String

  title     String
  synopsis  String? @db.Text
  sortOrder Int     @default(0)
  status    String  @default("draft")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips       Clip[]
  composition Composition?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("episodes")
}

// ─── Clips ─────────────────────────────────────────────────────────────────

model Clip {
  id        String @id @default(cuid())
  episodeId String

  title       String?
  description String? @db.Text
  dialogue    String? @db.Text
  screenplay  String? @db.Text
  sortOrder   Int     @default(0)

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  panels  Panel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([episodeId])
  @@map("clips")
}

// ─── Panels ─────────────────────────────────────────────────────────────────

model Panel {
  id     String @id @default(cuid())
  clipId String

  sceneDescription String? @db.Text
  cameraAngle      String?
  shotType         String?
  cameraMove       String?
  imagePrompt      String? @db.Text

  sceneType           String?
  videoPrompt         String? @db.Text
  sourceText          String? @db.Text
  photographyRules    String? @db.Text
  actingNotes         String? @db.Text
  candidateImages     String? @db.Text
  selectedImageIndex  Int     @default(0)
  videoGenerationMode String?

  imageUrl String? @db.MediumText
  videoUrl String? @db.MediumText

  durationMs Int @default(3000)
  sortOrder  Int @default(0)

  clip       Clip        @relation(fields: [clipId], references: [id], onDelete: Cascade)
  voiceLines VoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clipId])
  @@map("panels")
}

// ─── Voice Lines ────────────────────────────────────────────────────────────

model VoiceLine {
  id      String  @id @default(cuid())
  panelId String

  text     String  @db.Text
  audioUrl String? @db.Text
  speaker  String?
  emotion  String?

  startMs Int @default(0)
  endMs   Int @default(0)

  panel Panel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([panelId])
  @@map("voice_lines")
}

// ─── Compositions ───────────────────────────────────────────────────────────

model Composition {
  id        String @id @default(cuid())
  episodeId String @unique

  bgmUrl          String? @db.Text
  bgmVolume       Float   @default(0.3)
  subtitleEnabled Boolean @default(true)
  subtitleStyle   String  @default("default")
  transition      String  @default("crossfade")

  outputUrl  String? @db.Text
  srtContent String? @db.LongText
  status     String  @default("pending")
  progress   Int     @default(0)
  error      String? @db.Text

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("compositions")
}

// ─── Tasks ──────────────────────────────────────────────────────────────────

model Task {
  id        String  @id @default(cuid())
  projectId String?
  userId    String

  type    String
  status  String  @default("pending")
  payload Json?   @db.Json
  result  Json?   @db.Json
  error   String? @db.Text

  errorCode String?

  progress   Int @default(0)
  totalSteps Int @default(1)

  attempt     Int @default(0)
  maxAttempts Int @default(3)

  heartbeatAt DateTime?

  bullJobId String?

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  finishedAt  DateTime?
  completedAt DateTime?

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("tasks")
}
