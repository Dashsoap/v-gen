{
  "name": "v-gen",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:next\" \"npm run dev:worker\"",
    "dev:next": "next dev",
    "dev:worker": "tsx watch src/lib/workers/index.ts",
    "dev:watchdog": "tsx watch scripts/watchdog.ts",
    "build": "prisma generate && next build",
    "start": "concurrently --kill-others \"npm run start:next\" \"npm run start:worker\" \"npm run start:watchdog\"",
    "start:next": "next start -H 0.0.0.0",
    "start:worker": "tsx src/lib/workers/index.ts",
    "start:watchdog": "tsx scripts/watchdog.ts",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:board": "tsx scripts/bull-board.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fal-ai/client": "^1.2.0",
    "@google/genai": "^1.0.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.4.0",
    "@tanstack/react-query": "^5.65.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.40.0",
    "clsx": "^2.1.0",
    "ioredis": "^5.4.0",
    "lucide-react": "^0.470.0",
    "next": "^15.2.0",
    "next-auth": "^4.24.11",
    "next-intl": "^4.7.0",
    "openai": "^4.80.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@auth/core": "^0.34.3",
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "express": "^5.2.1",
    "postcss": "^8.5.0",
    "prisma": "^6.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
